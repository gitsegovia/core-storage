# ─── Server ───────────────────────────────────────────
PORT=4400
HOST=0.0.0.0
NODE_ENV=production

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://corestorage:corestorage_secret@db:5432/corestorage

# ─── Storage ──────────────────────────────────────────
# Ruta DENTRO del container donde se monta el volumen de storage.
# En docker-compose se mapea STORAGE_HOST_PATH → /data/storage
STORAGE_PATH=/data/storage
STORAGE_HOST_PATH=change_me_to_actual_host_path

# ─── Auth ─────────────────────────────────────────────
# Master key para endpoints de administración (crear/revocar sistemas).
# Generar con: openssl rand -hex 32
ADMIN_API_KEY=change_me_generate_a_secure_key

# ─── Signed URLs ──────────────────────────────────────
# Secret para firmar URLs temporales.
# Generar con: openssl rand -hex 32
SIGNED_URL_SECRET=change_me_generate_a_secure_secret

# Tiempo de expiración de URLs firmadas (en segundos). Default: 3600 (1 hora)
SIGNED_URL_EXPIRY=3600

# ─── Upload limits ────────────────────────────────────
# Tamaño máximo de archivo en bytes. Default: 104857600 (100MB)
MAX_FILE_SIZE=104857600

# ─── PostgreSQL (usado por el container de DB) ────────
POSTGRES_USER=corestorage
POSTGRES_PASSWORD=corestorage_secret
POSTGRES_DB=corestorage
